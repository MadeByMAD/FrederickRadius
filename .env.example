# Optional API keys — the app falls back gracefully when they are missing
VITE_CENSUS_API_KEY=
VITE_AIRNOW_API_KEY=
# Required for the interactive map. Without it, the app shows a dashboard-style overview state.
VITE_MAPBOX_TOKEN=
# Optional same-origin proxy for the Maryland CHART JSON feed in production deployments.
VITE_CHART_PROXY_URL=
